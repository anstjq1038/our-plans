rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 의견(댓글) — Google 로그인 필수
    // - 읽기: 누구나 (링크 공유용)
    // - 작성: 로그인한 본인 uid로만 + "플래너" 배지 사칭 금지
    // - 삭제: 본인이 쓴 것만 (서버에서 강제)
    // - 수정: 금지 (내용 변조 방지)
    match /trips/{tripId}/comments/{doc} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && !("agent" in request.resource.data);
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // 정산 지출 기록 — 로그인 필수, 본인 것만 삭제, 수정 금지
    match /trips/{tripId}/expenses/{doc} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.amount is number
                    && request.resource.data.amount > 0;
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // 사진 — 로그인 필수, 본인 것만 삭제, 크기 제한(문서 1MB 한도 보호)
    match /trips/{tripId}/photos/{doc} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.data is string
                    && request.resource.data.data.size() < 950000;
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // 사진 좋아요 — 문서 ID를 {photoId}_{uid}로 강제해 1인 1좋아요
    match /trips/{tripId}/photoLikes/{likeId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && likeId == request.resource.data.photoId + "_" + request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // 사진 댓글
    match /trips/{tripId}/photoComments/{doc} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // 화면에서 직접 추가한 계획 — 로그인 필수, 만든 사람만 수정·삭제
    match /plans/{planId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0;
      allow update, delete: if request.auth != null
                            && resource.data.uid == request.auth.uid;
    }

    // 그 외 모든 경로는 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
